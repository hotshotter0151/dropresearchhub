{
  "rewrites": [
    { "source": "/api/generate",       "destination": "/api/generate.js" },
    { "source": "/api/auth",           "destination": "/api/auth.js" },
    { "source": "/api/stripe-checkout","destination": "/api/stripe-checkout.js" },
    { "source": "/api/stripe-portal",  "destination": "/api/stripe-portal.js" },
    { "source": "/api/webhook",        "destination": "/api/webhook.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
